# EditorConfig helps maintain consistent coding styles across editors and IDEs.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Two trailing spaces is a valid Markdown hard line break; don't strip it.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[*.sh]
indent_size = 2
end_of_line = lf

[*.ps1]
indent_size = 4
